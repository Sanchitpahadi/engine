ui/FileBrowser.s: ui/FileBrowser.cpp.s
.PHONY : ui/FileBrowser.s

# target to generate assembly for a file
ui/FileBrowser.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/cpp.dir/build.make CMakeFiles/cpp.dir/ui/FileBrowser.cpp.s
.PHONY : ui/FileBrowser.cpp.s

